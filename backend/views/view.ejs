<%- include('./header', {title: title}) %>
<% if(findBook) {%>
    <h1 class="mb-3">Книга: <%= findBook.title %></h1>

<div class="card">
  <div class="card-body">
    <p>Автор: <%= findBook.authors %></p>
    <p>Описание: <%= findBook.description%></p>
    <p>Понравилась: <%= findBook.favorite%></p>
    <p>Скачать книгу: <a href="/api/books/<%= findBook.id %>/download">скачать</p>
    <div class="text-right">
      <a class="btn btn-sm btn-primary" href="/books/update/<%= findBook.id %>">
          <i class="fa fa-pencil" aria-hidden="true"></i>
      </a>
      <form action="/books/delete/<%= findBook.id %>" method="POST" class="d-inline">
          <button class="btn btn-sm btn-danger">
              <i class="fa fa-trash" aria-hidden="true"></i>
          </button>
      </form>
  </div>
  </div>
</div>
<% } else { %>
    <h3 class="mt-5">Книга не найдена</h3>
    <% } %>